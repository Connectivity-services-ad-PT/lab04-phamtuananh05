    {
      "name": "05_Consumer_side_Smoke",
      "item": [
        {
          "name": "12 Access Gate calls Core Business mock for access policy",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"personId\": \"SV001\",\n  \"cardId\": \"card-001\",\n  \"gateId\": \"gate-main\",\n  \"direction\": \"IN\",\n  \"timestamp\": \"2026-05-10T08:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{coreBusinessMockUrl}}/policies/evaluate-access",
              "host": [
                "{{coreBusinessMockUrl}}"
              ],
              "path": [
                "policies",
                "evaluate-access"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Core Business mock is reachable\", function () {",
                  "  pm.expect([200, 201, 400, 401, 403, 404, 422, 500]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if ([200, 201].includes(pm.response.code)) {",
                  "  pm.test(\"Consumer can parse policy response\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an(\"object\");",
                  "  });",
                  "}",
                  "",
                  "if ([400, 401, 403, 404, 422, 500].includes(pm.response.code)) {",
                  "  pm.test(\"Consumer understands provider error response\", function () {",
                  "    pm.expect(pm.response.code).to.be.within(400, 599);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
