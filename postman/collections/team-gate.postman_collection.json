                "cards",
                "card-001"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Missing token behavior is controlled\", function () {",
                  "  const env = pm.environment.get(\"env\");",
                  "  if (env === \"local\") {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  } else {",
                  "    pm.expect([200, 401, 403]).to.include(pm.response.code);",
                  "  }",
                  "});",
                  "",
                  "pm.test(\"Auth test documents mock limitation\", function () {",
                  "  pm.expect(pm.response.code).to.be.a(\"number\");",
                  "});"
                ]
              }
            }
