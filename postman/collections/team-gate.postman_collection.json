{
  "info": {
    "_postman_id": "team-gate-access-gate-lab03",
    "name": "FIT4110 Lab03 - Team Gate - Access Gate",
    "description": "Postman collection for Access Gate Service in Smart Campus Operations Platform. This collection tests functional, auth, negative, boundary, consumer-side smoke and local-only non-functional scenarios.",
