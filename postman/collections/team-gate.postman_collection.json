              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Invalid limit returns controlled response\", function () {",
                  "  const env = pm.environment.get(\"env\");",
                  "  if (env === \"local\") {",
                  "    pm.expect([400, 422]).to.include(pm.response.code);",
