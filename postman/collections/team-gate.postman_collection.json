    {
      "name": "02_Auth",
      "item": [
        {
          "name": "06 Missing token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "55555555-5555-5555-5555-555555555555"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cards/card-001",
              "host": [
